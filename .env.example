# ============================================================
# hAI.CalBoard – .env Vorlage
# Nur ADMIN_PASSWORD und SECRET_KEY sind beim ersten Start
# zwingend erforderlich. Alles andere kann im Admin-Panel
# unter http://deine-ip:4455/admin eingetragen werden.
# ============================================================

# ── PFLICHTFELDER (Server startet nicht ohne diese!) ──
ADMIN_PASSWORD=dein_sicheres_passwort
SECRET_KEY=aendere_mich_bitte_in_einen_langen_zufaelligen_string

# ── GOOGLE OAUTH (optional – im Admin-Panel einstellbar) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── KALENDER (optional – im Admin-Panel auswählbar) ──
CALENDAR_IDS=primary

# ── WETTER (optional – im Admin-Panel einstellbar) ──
OPENWEATHER_API_KEY=
CITY=Pfinztal
