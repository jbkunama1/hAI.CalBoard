# Google OAuth
GOOGLE_CLIENT_ID=dein_client_id
GOOGLE_CLIENT_SECRET=dein_client_secret
GOOGLE_REFRESH_TOKEN=dein_refresh_token

# Kalender (kommagetrennt, wird im Admin überschrieben)
CALENDAR_IDS=primary

# Wetter
OPENWEATHER_API_KEY=dein_openweather_key
CITY=Pfinztal

# Admin-Passwort für /admin
ADMIN_PASSWORD=dein_sicheres_passwort

# Flask Session Key (zufälligen Wert eintragen)
SECRET_KEY=aendere_mich_bitte_in_einen_zufaelligen_langen_string
